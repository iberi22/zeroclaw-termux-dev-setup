# =============================================================================
# ZeroClaw SWAL Node — Environment Configuration
# =============================================================================
# Copia este archivo a .env.swal y configura tus API keys
# =============================================================================

# ── ZeroClaw Core ───────────────────────────────────────────────────────────
# API Key para tu provider LLM (OpenRouter recomendado para múltiples modelos)
API_KEY=sk-or-v1-tu-api-key-aqui

# Provider y modelo por defecto
PROVIDER=openrouter
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
DEFAULT_TEMPERATURE=0.7

# Puerto del gateway
ZEROCLAW_GATEWAY_PORT=42617

# ── SWAL Integrations ──────────────────────────────────────────────────────

# Cortex Memory System
CORTEX_URL=http://cortex:8003
CORTEX_TOKEN=dev-token
SWAL_CORTEX_ENABLED=true

# Gestalt Swarm
SWAL_GESTALT_ENABLED=false
GESTALT_MAX_AGENTS=10
GESTALT_PROVIDER=groq

# ── Provider API Keys ───────────────────────────────────────────────────────
# Descomenta y añade tus API keys según los providers que uses

# OpenRouter (agregador — recomendación para SWAL)
# API_KEY=sk-or-v1-...

# Groq (para Gestalt Swarm)
# GROQ_API_KEY=gsk_...

# Google Gemini (para Gemini CLI provider en ZeroClaw)
# GEMINI_API_KEY=AIza...

# OpenAI (directo)
# OPENAI_API_KEY=sk-...

# Anthropic (directo)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Security ───────────────────────────────────────────────────────────────
# Permitir bind público (true solo si el contenedor está en red confiable)
ZEROCLAW_ALLOW_PUBLIC_BIND=false
ZEROCLAW_REQUIRE_PAIRING=true

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info,zeroclaw=debug
RUST_BACKTRACE=1

# ── Docker Control ──────────────────────────────────────────────────────────
# Habilitar servicios opcionales (solo con --profile)
# docker compose --profile with-cortex --profile with-gestalt up -d

# Cortex Memory Server (integrado en docker-compose.swal.yml)
CORTEX_PORT=8003
CORTEX_IMAGE=ghcr.io/iberi22/cortex:latest

# Gestalt Swarm Bridge
GESTALT_PORT=9150
GESTALT_IMAGE=ghcr.io/iberi22/gestalt-swarm:latest
