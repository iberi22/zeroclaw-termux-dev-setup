# =============================================================================
# ZeroClaw SWAL Agent — Environment
# =============================================================================

# ── ZeroClaw Core ───────────────────────────────────────────────────────────
API_KEY=sk-or-v1-tu-api-key
PROVIDER=openrouter
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
DEFAULT_TEMPERATURE=0.7

# ── Gateway ─────────────────────────────────────────────────────────────────
ZEROCLAW_GATEWAY_PORT=42617

# ── Workspace (proyectos) ────────────────────────────────────────────────────
# Se monta desde ./../ del host (padre de zeroclaw)
# Así el agente ve todos los proyectos

# ── Tools ───────────────────────────────────────────────────────────────────
ZEROCLAW_ALLOW_SHELL=true
ZEROCLAW_ALLOW_GIT=true
ZEROCLAW_ALLOW_FILE_WRITE=true

# ── SWAL Cortex ────────────────────────────────────────────────────────────
# Si Cortex corre en host, usar host.docker.internal
CORTEX_URL=http://host.docker.internal:8003
CORTEX_TOKEN=dev-token
SWAL_CORTEX_ENABLED=true

# ── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=info,zeroclaw=debug
RUST_BACKTRACE=1

# ── Docker ──────────────────────────────────────────────────────────────────
# Solo para iniciar cortex dentro de compose
CORTEX_IMAGE=ghcr.io/iberi22/cortex:latest
