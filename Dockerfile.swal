# =============================================================================
# ZeroClaw SWARM Node - Dockerfile
# =============================================================================
# Imagen Docker con TODAS las tools de desarrollo
# Schwerpunkt: Dev environment, NO heavy compilation (Rust OOM in Docker)
# =============================================================================

FROM debian:trixie-slim

# =============================================================================
# Labels
# =============================================================================
LABEL maintainer="Belal <https://github.com/iberi22>"
LABEL description="ZeroClaw SWARM Node - Full dev environment with AI agents"
LABEL version="1.0.0"

# =============================================================================
# ENV
# =============================================================================
ENV LANG=C.UTF-8 LC_ALL=C.UTF-8
ENV EDITOR=nano VISUAL=nano PAGER=less
ENV NPM_CONFIG_LOGLEVEL=info
ENV RUST_BACKTRACE=1
ENV CARGO_BUILD_JOBS=2
ENV DEBIAN_FRONTEND=noninteractive

# =============================================================================
# BASE SYSTEM - Todo en una sola capa para minimizar imagen
# =============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget git vim nano unzip zip \
    htop tree jq ripgrep fd-find fzf \
    build-essential pkg-config cmake ninja-build clang make autoconf automake libtool \
    openssl libssl-dev \
    nodejs npm \
    golang-go \
    default-jdk maven \
    ruby ruby-dev \
    php php-cli php-mbstring php-xml php-curl php-zip \
    sqlite3 postgresql-client redis-tools \
    netcat-openbsd telnet dnsutils \
    tmux screen rsync tar gzip bzip2 p7zip-full \
    tzdata sudo gnupg2 \
    python3 python3-pip python3-venv python3-dev \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# =============================================================================
# SSH - Agent user
# =============================================================================
RUN useradd -m -s /bin/bash -G sudo,www-data agent && \
    echo "agent ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers && \
    mkdir -p /home/agent/.ssh && \
    chown -R agent:agent /home/agent

# =============================================================================
# SCRIPTS
# =============================================================================
COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY scripts/healthcheck.sh /usr/local/bin/healthcheck.sh
COPY scripts/start-zeroclaw.sh /usr/local/bin/start-zeroclaw.sh
RUN chmod +x /usr/local/bin/*.sh
RUN chmod +x /usr/local/bin/start-zeroclaw.sh

# =============================================================================
# NODE.JS - NodeSource LTS + Globals
# =============================================================================
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm yarn typescript ts-node ts-node-dev @types/node prettier eslint dotenv-cli cross-env neovim wrangler

# =============================================================================
# PYTHON - Use system pip with break-system-packages
# =============================================================================
RUN pip3 install --break-system-packages --no-deps --ignore-installed \
    requests httpx aiohttp fastapi uvicorn pydantic \
    openai anthropic groq google-generativeai langchain langchain-community \
    pandas numpy matplotlib jupyter ipython \
    black ruff mypy pytest pytest-asyncio \
    python-dotenv pyyaml toml rich typer click \
    sqlalchemy psycopg2-binary redis beautifulsoup4 \
    lxml pillow scikit-learn

# =============================================================================
# GO - Solo swag (herramienta pequena)
# =============================================================================
RUN go install github.com/swaggo/swag/cmd/swag@latest 2>/dev/null || true

# =============================================================================
# SUPABASE CLI
# =============================================================================
RUN curl -fsSL https://github.com/supabase/cli/releases/latest/download/supabase_linux_amd64.tar.gz -o /tmp/supabase.tar.gz && \
    tar -xzf /tmp/supabase.tar.gz -C /tmp && \
    mv /tmp/supabase /usr/local/bin/ && chmod +x /usr/local/bin/supabase || true
RUN rm -f /tmp/supabase.tar.gz

# =============================================================================
# TERRAFORM
# =============================================================================
RUN curl -fsSL https://releases.hashicorp.com/terraform/1.9.0/terraform_1.9.0_linux_amd64.zip -o /tmp/terraform.zip && \
    unzip -o /tmp/terraform.zip -d /usr/local/bin/ && rm /tmp/terraform.zip

# =============================================================================
# PULUMI (lightweight install)
# =============================================================================
RUN curl -fsSL https://get.pulumi.com | sh -s -- --version 3.128.0
ENV PATH="/root/.pulumi/bin:${PATH}"

# =============================================================================
# GESTALT CLI - Placeholder (build in host, too heavy for Docker OOM)
# =============================================================================
RUN echo '#!/bin/bash' > /usr/local/bin/gestalt_cli && echo 'echo "gestalt_cli PLACEHOLDER"' >> /usr/local/bin/gestalt_cli && echo 'exit 1' >> /usr/local/bin/gestalt_cli && chmod +x /usr/local/bin/gestalt_cli

# =============================================================================
# ZERO CLAW - Placeholder (repo potentially private, build OOM)
# =============================================================================
RUN echo '#!/bin/bash' > /usr/local/bin/zeroclaw && echo 'echo "zeroclaw PLACEHOLDER"' >> /usr/local/bin/zeroclaw && echo 'exit 1' >> /usr/local/bin/zeroclaw && chmod +x /usr/local/bin/zeroclaw

# =============================================================================
# WORKSPACE + DIAGNOSTIC
# =============================================================================
WORKDIR /zeroclaw
RUN mkdir -p /zeroclaw/workspace /zeroclaw/skills/openclaw /zeroclaw/logs

# =============================================================================
# FINAL
# =============================================================================
USER agent
WORKDIR /home/agent

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
